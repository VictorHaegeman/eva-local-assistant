{
  "manifest_version": 3,
  "name": "Eva Browser Bridge",
  "description": "Pont local Brave <-> Eva pour lire la page active et piloter les entrainements navigateur.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Eva Browser Bridge",
    "default_popup": "popup.html"
  }
}
